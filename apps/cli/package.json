    "@lockbox/generator": "workspace:*",
    "@lockbox/types": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^4.0.18",
    "tsx": "^4.0.0"
  }
}
