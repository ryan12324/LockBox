{
  "name": "@lockbox/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Lockbox CLI — manage your vault from the terminal",
  "type": "module",
  "bin": {
    "lockbox": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
