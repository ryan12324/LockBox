{
  "name": "@lockbox/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Capacitor Android app for lockbox password manager",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "build:android": "tsc && npx cap sync android",
    "dev:android": "tsc --watch & npx cap run android",
    "sync": "npx cap sync",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/network": "^6.0.0",
    "@lockbox/types": "*"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
