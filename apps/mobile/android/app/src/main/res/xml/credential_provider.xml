<?xml version="1.0" encoding="utf-8"?>
<!--
  Credential Provider capability declaration.
  Registers Lockbox as a system-level passkey provider on Android 14+.
  The system will query LockboxCredentialProviderService for public-key credentials.
-->
<credential-provider xmlns:android="http://schemas.android.com/apk/res/android">
    <capabilities>
        <capability name="android.credentials.TYPE_PUBLIC_KEY_CREDENTIAL" />
    </capabilities>
</credential-provider>
